# ============================================================================
# SwingAI — Environment Variables
# Copy to .env and fill in your values
# ============================================================================

# APPLICATION
APP_ENV=development          # development | staging | production
DEBUG=False
SECRET_KEY=change-this-to-a-random-string

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# MARKET DATA PROVIDER
DATA_PROVIDER=yfinance       # yfinance | truedata
TRUEDATA_USERNAME=
TRUEDATA_PASSWORD=
TRUEDATA_LIVE_PORT=8084
TRUEDATA_INIT_TIMEOUT=30

# RAZORPAY (Payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# BROKER API KEYS
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URI=
ANGEL_API_KEY=
ANGEL_REDIRECT_URI=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
BROKER_ENCRYPTION_KEY=

# REDIS (optional — set ENABLE_REDIS=True to activate)
ENABLE_REDIS=False
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://swingai.vercel.app
FRONTEND_URL=http://localhost:3000

# ML MODELS
ML_INFERENCE_URL=
ENHANCED_ML_INFERENCE_URL=
XGBOOST_MODEL_PATH=models/xgboost_model.json
TFT_MODEL_PATH=models/tft_model.ckpt
TFT_CONFIG_PATH=models/tft_config.json

# MONITORING
LOG_LEVEL=INFO
SENTRY_DSN=

# FEATURES
ENABLE_SCHEDULER=False
ENABLE_ENHANCED_AI=False
ENABLE_FINANCE_ASSISTANT=False

# FINANCE ASSISTANT (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# PUSH NOTIFICATIONS (replaces Telegram — used for Starter/Pro plans)
# FCM_SERVER_KEY=
# APNS_KEY_ID=

# TRADING
PAPER_TRADE_DAYS=14
STRATEGY_MIN_CONFLUENCE=0.6
EOD_SCAN_SOURCE=github
EOD_SCAN_TYPE=swing

# RATE LIMITING
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
