# ============================================================================
# Quant X — Environment Variables
# Copy to .env and fill in your values
# ============================================================================

# ── APPLICATION ─────────────────────────────────────────────────────────────
APP_ENV=development                # development | staging | production
DEBUG=False
SECRET_KEY=change-this-to-a-random-string

# ── SUPABASE ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# JWT signing secret — Supabase Dashboard → Settings → API → JWT Secret.
# CRITICAL in production. Empty = JWT signature verification DISABLED = admin spoofing possible.
SUPABASE_JWT_SECRET=

# ── ADMIN ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com     # comma-separated admin email list

# ── MARKET DATA PROVIDER ───────────────────────────────────────────────────
DATA_PROVIDER=free               # "free" (yfinance, no API key) or "kite" (Zerodha Kite Connect)

# ── KITE ADMIN (only needed if DATA_PROVIDER=kite) ───────────────────────
KITE_ADMIN_API_KEY=              # Kite Connect API key (admin account)
KITE_ADMIN_API_SECRET=           # Kite Connect API secret
KITE_ADMIN_ACCESS_TOKEN=         # Access token (refresh daily via /admin/kite/refresh-token)
# Auto-login for daily token refresh (optional — set all 3 for automation)
KITE_ADMIN_USER_ID=              # Zerodha client ID (e.g., AB1234)
KITE_ADMIN_PASSWORD=             # Zerodha login password
KITE_ADMIN_TOTP_SECRET=          # TOTP secret from Zerodha 2FA setup (base32 string)

# ── RAZORPAY (Payments) ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── BROKER API KEYS ────────────────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URI=
ANGEL_API_KEY=
ANGEL_REDIRECT_URI=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
BROKER_ENCRYPTION_KEY=

# ── REDIS (optional — set ENABLE_REDIS=True to activate) ───────────────────
ENABLE_REDIS=False
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── CORS (production: set to your actual domain, no localhost) ──────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# ALLOWED_ORIGINS=https://quantx.app  # production example
FRONTEND_URL=http://localhost:3000

# ── ML MODELS ──────────────────────────────────────────────────────────────
ML_INFERENCE_URL=
ENHANCED_ML_INFERENCE_URL=
ML_MODEL_PATH=ml/models            # directory for local model artifacts
XGBOOST_MODEL_PATH=models/xgboost_model.json
TFT_MODEL_PATH=models/tft_model.ckpt
TFT_CONFIG_PATH=models/tft_config.json
MODEL_STORAGE_BUCKET=models        # Supabase storage bucket name for models

# ── MODEL REGISTRY (Backblaze B2 + model_versions table) ───────────────────
# Create a B2 bucket named swingai-models and an application key scoped to it.
# Version metadata lives in Postgres (public.model_versions — see PR 2 migration).
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_MODELS=swingai-models
MODEL_CACHE_DIR=.model_cache       # local cache path for downloaded artifacts

# ── MONITORING ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=

# ── TELEGRAM (optional: push notifications via Telegram bot) ───────────────
TELEGRAM_BOT_TOKEN=                # Bot token from @BotFather
TELEGRAM_CHAT_ID=                  # Target chat / group ID for alerts

# ── WEBSOCKET ──────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30           # seconds between keep-alive pings

# ── FEATURES ────────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=True              # auto-run EOD scan, position monitoring, market close
ENABLE_BROKER_TICKER=True            # enable per-user broker WebSocket ticker streaming
ENABLE_ENHANCED_AI=False
ENABLE_FINANCE_ASSISTANT=False

# ── FINANCE ASSISTANT (Gemini) ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ASSISTANT_PUBLIC_MODEL_NAME=Quant X Finance Intelligence
ASSISTANT_MAX_HISTORY_MESSAGES=16
ASSISTANT_MAX_USER_MESSAGE_CHARS=1200
ASSISTANT_DAILY_CREDITS_FREE=5     # daily AI-chat credits for free-tier users
ASSISTANT_DAILY_CREDITS_PRO=150    # daily AI-chat credits for Pro-tier users
ASSISTANT_HTTP_TIMEOUT_SECONDS=8   # timeout for external news feed fetches

# ── TRADING ─────────────────────────────────────────────────────────────────
PAPER_TRADE_DAYS=14                # days a user must paper-trade before going live
LIVE_TRADING_WHITELIST_ONLY=True   # restrict live trading to whitelisted symbols
STRATEGY_MIN_CONFLUENCE=0.6        # minimum signal confluence score (0.0 – 1.0)
STRATEGY_TOP_N=3                   # top N strategies to combine
STRATEGY_WEIGHT=0.6                # weight for rule-based strategy score
XGB_WEIGHT=0.2                     # weight for XGBoost model score
TFT_WEIGHT=0.2                     # weight for TFT model score

# Alpha universe
ALPHA_UNIVERSE_FILE=data/alpha_universe.txt   # path to curated symbol list
ALPHA_UNIVERSE_SIZE=100                       # max symbols in the alpha universe
NSE_HOLIDAYS_FILE=data/nse_holidays_2026.json # NSE holiday calendar (JSON)

# EOD scanner
EOD_SCAN_SOURCE=github             # github | local
EOD_SCAN_TYPE=swing                # swing | trend | momentum | breakout
EOD_SCAN_USE_PKS=True              # use PKScreener for stock universe discovery
EOD_SCAN_MIN_PRICE=50              # minimum stock price filter (INR)
EOD_SCAN_MAX_PRICE=10000           # maximum stock price filter (INR)
EOD_SCAN_MIN_VOLUME=200000         # minimum average daily volume filter
EOD_SCAN_MAX_STOCKS=300            # cap on stocks returned by scanner

# Built-in universe screener (lightweight PKScreener fallback)
SCREENER_ENABLED=True              # enable built-in screener when PKS unavailable
SCREENER_MAX_CANDIDATES=70         # max candidate stocks to return
SCREENER_BATCH_SIZE=200            # symbols per batch when fetching data
SCREENER_DATA_PERIOD=3mo           # period string for screening data (e.g. 3mo, 6mo)
SCREENER_MIN_TRADING_DAYS=20       # discard symbols with fewer trading days
SCREENER_MAX_VOLATILITY=0.08       # reject symbols above this daily volatility
SCREENER_SYMBOL_CACHE_DAYS=7       # days to cache NSE symbol list
FNO_INSTRUMENTS_FILE=data/fno_instruments.csv  # FnO instruments reference file

# ── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── WEB PUSH (VAPID) ─────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@swingai.in

# ── EMAIL (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=SwingAI <alerts@swingai.in>
